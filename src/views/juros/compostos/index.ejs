<!doctype html>
<html lang="en" data-bs-theme="<%=theme%>">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Capitalização Composta</title>

  <link rel="stylesheet" href="/css/style.css" />
  <script type="module" src="/js/mathJaxHelper.js"></script>
  <script type="module" src="/js/formUtils.js"></script>
  <script type="module" src="/js/themeSwitcher.js"></script>

  <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js" defer></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous" defer></script>
</head>

<body class="bg-<%=theme%>">
  <div class="d-flex flex-row justify-content-between">
    <h2 class="p-3">Calculadora Financeira - Capitalização Composta</h2>
    <button class="my-auto me-5" id="theme-switcher-btn" style="border: none; background: none">
      <svg id="theme-switcher-svg" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="width: 25px;">
        <g id="SVGRepo_bgCarrier" stroke-width="0"></g>
        <g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g>
        <g id="SVGRepo_iconCarrier">
          <path id="theme-swithcer-svg-path" d="M9 3V7M15 3V6M4 10H20M12 21C10.2337 21 8.91561 19.3737 9.28133 17.6457L9.34332 17.3528C9.56076 16.3254 9.04388 15.2832 8.09439 14.8346L5.9897 13.8401C4.77487 13.2661 4 12.043 4 10.6994V4.63149C4 3.73044 4.73044 3 5.63149 3H18.3685C19.2696 3 20 3.73044 20 4.63149V10.6994C20 12.043 19.2251 13.2661 18.0103 13.8401L15.9056 14.8346C14.9561 15.2832 14.4392 16.3254 14.6567 17.3528L14.7187 17.6457C15.0844 19.3737 13.7663 21 12 21Z" stroke="#<%if (theme && theme === 'dark') {%>ffffff<%} else { %>000000<%}%>" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </g>
      </svg>
    </button>
  </div>
  <hr />

  <div class="px-3">
    <div class="p-3 container-sm border shadow-sm rounded-2 centered-card">
      <form hx-post="/juros/compostos" hx-target="#result" hx-swap="innerHTML">
        <div class="input-group mb-3">
          <label for="target" class="input-group-text">Calcular:
          </label>
          <select name="target" id="target" class="form-select">
            <option value="capital">Capital (VP)</option>
            <option value="montante">Montante (VF)</option>
            <option value="juros">Juros (J)</option>
            <option value="taxa">Taxa (i)</option>
            <option value="tempo">Tempo (n)</option>
          </select>
        </div>
        <div id="input-entry" class="mb-3">
        </div>
        <button type="submit" id="calculate-confirm" class="btn btn-primary">Calcular</button>
      </form>



      <div id="result">
      </div>
    </div>
  </div>

  <div class="px-3">
    <div class="my-3 p-3 container-sm border shadow-sm rounded-2 centered-card">

      <h3 class="mb-3">Proporção de taxas</h3>

      <form hx-post="/juros/compostos/proporcao" hx-target="#result-prop" hx-swap="innerHTML">

        <div class="item input-group">
          <label class="input-group-text" for="taxa-efetiva">
            Taxa proporcional (efetiva) (i):
          </label>
          <input name="taxaEfetiva" id="taxa-efetiva" type="number" step="0.01" class="form-control" />
        </div>

        <div class="item input-group">
          <label class="input-group-text" for="taxa-nominal">
            Taxa nominal (i<sub>k</sub>)
          </label>
          <input name="taxaNominal" id="taxa-nominal" type="number" step="0.01" class="form-control" />
        </div>

        <div class="item input-group mb-3">
          <label class="input-group-text" for="tempo-prop">Tempo (k):</label>
          <input name="tempo" id="tempo-prop" type="number" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary">
          Converter
        </button>
      </form>
      <div id="result-prop">
      </div>
    </div>
  </div>


<div class="px-3">
    <div class="my-3 p-3 container-sm border shadow-sm rounded-2 centered-card">

      <h3 class="mb-3">Equivalência de taxas</h3>

      <form hx-post="/juros/compostos/equivalencia" hx-target="#result-conv" hx-swap="innerHTML">

        <div class="item input-group">
          <label class="input-group-text" for="taxa-efetiva">
            Taxa efetiva (i):
          </label>
          <input name="taxaEfetiva" id="taxa-efetiva" type="number" step="0.01" class="form-control" />
        </div>

        <% if (periods) { %>
        <div class=" item input-group">
            <label class="input-group-text" for="fromEquivTaxa">De</label>
            <select name="from" id="fromEquivTaxa" class="form-select">
              <% periods.forEach((period) => { %>
              <option value="<%=period%>"><%=period%></option>
              <% }); %>
            </select>
  </div>
  <% } %>


  <% if (periods) { %>
  <div class=" item input-group">
    <label class="input-group-text" for="toEquivTaxa">Para</label>
    <select name="to" id="toEquivTaxa" class="form-select">
      <% periods.forEach((period) => { %>
      <option value="<%=period%>"><%=period%></option>
      <% }); %>
    </select>
  </div>
  <% } %>

  <button type="submit" class="btn btn-primary">
    Converter
  </button>
  </form>
  <div id="result-conv">
  </div>
  </div>
  </div>


</body>

</html>